{
  "name": "syntaxwp/plugin",
  "description": "SyntaxWP WordPress plugin — heartbeat/event reporting, signed work-order execution, and safety controls (Task A6/A7).",
  "type": "wordpress-plugin",
  "license": "proprietary",
  "require": {
    "php": ">=7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "mockery/mockery": "^1.6",
    "10up/wp_mock": "^1.1"
  },
  "autoload": {
    "psr-4": {
      "SyntaxWP\\Plugin\\": ""
    },
    "exclude-from-classmap": ["tests/"]
  },
  "autoload-dev": {
    "psr-4": {
      "SyntaxWP\\Plugin\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": false
  }
}
