{
  "name": "syntaxwp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n dashboard,api,worker -c blue,green,yellow \"pnpm --filter @syntaxwp/dashboard dev\" \"pnpm --filter @syntaxwp/api dev\" \"pnpm --filter @syntaxwp/api worker\"",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "5.7.3"
  }
}
